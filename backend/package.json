{
  "name": "vrv",
  "version": "1.0.0",
  "description": "Valorant Replay Viewer",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "generate": "openapi-generator-cli generate -g typescript-axios -i openapi/riot-client-openapi.json -o gen/ --global-property apiDocs=false,modelDocs=false",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=development nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "package": "pkg . -t node24-win-x64 --output binaries/ValorantReplayViewer",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run test/**/*.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/platform-ws": "^11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/websockets": "^11.1.19",
    "@types/lodash.merge": "^4.6.9",
    "@types/ws": "^8.18.1",
    "@yao-pkg/pkg": "^6.19.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "lodash.merge": "^4.6.2",
    "multer": "^2.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@openapitools/openapi-generator-cli": "^2.32.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.18",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "adm-zip": "^0.5.17",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "bin": "dist/src/main.js",
  "pkg": {
    "assets": [
      "dist/public/**/*",
      "dist/config.yml"
    ]
  }
}
